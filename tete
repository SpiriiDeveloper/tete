local function getClosestColorName(targetColor)
    local closestName = "Institutional white"
    local minDiff = math.huge
    for name, c3 in pairs(EliteColors) do
        local rDiff = (c3.R - targetColor.R) * 255
        local gDiff = (c3.G - targetColor.G) * 255
        local bDiff = (c3.B - targetColor.B) * 255
        local totalDiff = math.sqrt(rDiff*rDiff + gDiff*gDiff + bDiff*bDiff)
        if totalDiff < minDiff then
            minDiff = totalDiff
            closestName = name
        end
    end
    return closestName
end

