                if bloqueActualIndex % 5 == 0 and SpiriiIO.Write then
                    SpiriiIO.Write(nombreProgreso, tostring(bloqueActualIndex))
                end
            end
        end

        construyendo = false
        BuildBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 200)

        if construccionPausada then
