                            if nombreMueble == data.Nombre then
                                local idMueble = mueble:GetAttribute("Id")
                                if idMueble then
                                    mueble:SetAttribute("SpiriiAutoScaled", true)
                                    task.spawn(function()
                                        pcall(function()
                                            WebSocket.callRemote("PlotSystem", "scaleFurniture", tostring(idMueble), cframeSeguro, sizeSeguro)
                                        end)
                                    end)
                                    break
                                end
                            end
                        end
                    end
                end
