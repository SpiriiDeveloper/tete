                    ColorName = cName,
                    Material = mat
                })
            end
            
            table.sort(datosCasaMemoria, function(a, b)
                local posA = a.CFrameRelativo.Position
                local posB = b.CFrameRelativo.Position
                if math.abs(posA.Y - posB.Y) > 0.01 then return posA.Y < posB.Y
                elseif math.abs(posA.X - posB.X) > 0.01 then return posA.X < posB.X
                else return posA.Z < posB.Z end
            end)

