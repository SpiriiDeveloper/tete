            BuildBtn.Text = "4. CONSTRUIR 1x1"
            bloqueActualIndex = 1 
            if SpiriiIO.Write then SpiriiIO.Write(nombreProgreso, "1") end
        end
    end)
end)

-- ==========================================
-- [!] AUTO PINTOR CON LÓGICA DE TARGET PERFECTO
-- ==========================================
local function iniciarAutoPintura()
    local cubo = LocalPlayer.Character:FindFirstChild("PaintBucket") or LocalPlayer.Backpack:FindFirstChild("PaintBucket")
    if not cubo then
        StatusLabel.Text = "ERROR: Equipa el PaintBucket primero."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        return
    end

    local paintRemote = cubo:FindFirstChild("Remotes") and cubo.Remotes:FindFirstChild("ServerControls")
    if not paintRemote then 
        StatusLabel.Text = "ERROR: Remoto de pintura no encontrado."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
        return 
    end

    construyendo = true
    construccionPausada = false
    PaintExecBtn.Text = "PINTANDO..."
    PaintExecBtn.BackgroundColor3 = Color3.fromRGB(100, 50, 100)
    
    local miT = obtenerMiPlotFolder()
    local container = miT:WaitForChild("FurnitureContainer")
    local miBase = miT:FindFirstChildWhichIsA("BasePart")

    local indexPintura = 1
    
    while indexPintura <= #datosCasaMemoria do
        if construccionPausada then break end
        
        local data = datosCasaMemoria[indexPintura]
        local posFinal = miBase.CFrame * data.CFrameRelativo

        StatusLabel.Text = "Pintando: " .. indexPintura .. " / " .. #datosCasaMemoria
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 200)

        for _, mueble in ipairs(container:GetChildren()) do
            local dist = (mueble:GetPivot().Position - posFinal.Position).Magnitude
            if dist < 15 and not mueble:GetAttribute("SpiriiAutoPainted") then
                local p = obtenerParteVisible(mueble)
                if p then
                    local nombreMueble = identificarModeloExacto(mueble, p)
                    if nombreMueble == data.Nombre then
                        mueble:SetAttribute("SpiriiAutoPainted", true)
                        local eliteColor = EliteColors[data.ColorName] or Color3.new(1,1,1)
                        
                        local targetPaint = obtenerParteParaPintar(mueble)
                        
                        if targetPaint then
                            pcall(function()
                                paintRemote:InvokeServer("PaintPart", {
                                    ["Part"] = targetPaint,
                                    ["Color"] = eliteColor,
                                    ["Material"] = data.Material
                                })
                            end)
                        end
                        break 
                    end
                end
            end
        end
        
        task.wait(0.15)
        indexPintura = indexPintura + 1
    end

    construyendo = false
    PaintExecBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 200)

    if construccionPausada then
        StatusLabel.Text = "PINTURA PAUSADA."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
        PaintExecBtn.Text = "REANUDAR PINTURA"
    else
        StatusLabel.Text = "¡CASA PINTADA By:Spirii!"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 200)
        PaintExecBtn.Text = "6. AUTO-PINTAR CASA"
        PaintScanBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 150)
        PaintScanBtn.Text = "5. PREPARAR PINTOR"
    end
end

PaintExecBtn.MouseButton1Click:Connect(function()
    if construyendo then return end
    if #datosCasaMemoria == 0 then StatusLabel.Text = "Carga o escanea una casa primero."; return end
    
    task.spawn(function()
        iniciarAutoPintura()
    end)
end)
